# Face Liveness Detection - Production Configuration
# Copy to .env and adjust values

# Flask Configuration
FLASK_ENV=production
DEBUG=False
SECRET_KEY=change-me-to-a-secure-random-key

# Server Configuration
HOST=0.0.0.0
PORT=5000
WORKERS=4

# Model Configuration
MODEL_V1_PATH=models/best_checkpoint.pth
MODEL_V2_PATH=models/best_checkpoint_v2.pth
DEFAULT_THRESHOLD=0.5
THRESHOLD_MIN=0.3
THRESHOLD_MAX=0.9

# Image Processing
MAX_IMAGE_SIZE_MB=10
SUPPORTED_FORMATS=jpg,jpeg,png
IMAGE_QUALITY=85

# CORS Configuration
ALLOWED_ORIGINS=*

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/server.log

# GPU/CUDA Configuration
CUDA_ENABLED=True
CUDA_DEVICE=0

# API Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# Cache Configuration
CACHE_ENABLED=True
CACHE_TTL=3600

# Security
HTTPS_ONLY=True
SECURE_HEADERS=True
CORS_MAX_AGE=3600
